{
  "version": 2,
  "_comment": "Binder taxonomy for the binder-organize skill. Conformed to the cch-axcess skill's binder templates (binder-template.xlsx standard / binder-program-template-ebp.xlsx EBP) — those templates are the ruled index; fix drift HERE to the template, never the other way. Section folders use 4-digit indexes so the organized folder matches the firm's CCH Axcess binders. Folder labels may be shortened versions of the template group names; the index is the identity. Edit this file to retune categories, keywords, or naming WITHOUT touching skill code. Folder name = '<index> <name>'.",

  "folder_name_format": "{index} {name}",

  "catch_all": {
    "name": "Other",
    "indexed": false,
    "_comment": "Non-indexed folder for documents that fit no section. Sorts last."
  },

  "samples": {
    "subfolder": "Samples",
    "_comment": "A file flagged as a sample is filed into its real substantive section, then placed in a 'Samples' subfolder so the sample status is carried by the folder structure. e.g. '1200 Receivables, net/Samples/'.",
    "keywords": ["sample", "selection", "selections", "testing", "test work",
                 "testwork", "confirmation", "confirmations", "confirm",
                 "items selected", "selected items", "detail tested",
                 "sampling", "test of detail", "tod "]
  },

  "perm_file": {
    "index": "9000",
    "name": "Perm File",
    "mode": "flat_dump",
    "_comment": "Perm file is one flat folder by default for STANDARD clients. For client types listed under 'subfolders' (per the EBP binder template's 9100/9200/9300), a perm-bucket file is matched against the topical rules and filed into the matching subfolder; no match stays at the 9000 root. Optional date_split (off unless the user asks) applies only to files no topical rule claimed.",
    "date_split": {
      "enabled_by_default": false,
      "carryforward": "Carryforward",
      "current": "New This Year",
      "undated_stays_at_root": true,
      "_comment": "carryforward = document dated before the current fiscal year; current = dated in the current FY or later; undated docs stay at the 9000 root."
    },
    "keywords": ["permanent", "perm file", "bylaws", "by-laws",
                 "articles of incorporation", "articles of organization",
                 "lease agreement", "loan agreement", "debt agreement",
                 "contract", "agreement", "policy", "policies",
                 "tax exemption", "determination letter", "irs letter",
                 "amendment", "plan document", "adoption agreement",
                 "trust agreement", "trust document", "organizational document",
                 "governing document", "charter", "prior year",
                 "permanent file",
                 "spd", "summary plan description", "board resolution",
                 "soc 1", "soc1", "soc-1", "soc 2", "soc2",
                 "service auditor", "bridge letter", "gap letter"],
    "subfolders": {
      "_comment": "Ruled topical subfolders per client type, from the EBP binder template SECTION 90 (9100 Plan Documents / 9200 Service Agreements / 9300 SOC 1 Reports). Scored like classify(): most keyword hits wins; zero hits stays at the 9000 root. The standard template rules no subfolders, so 'standard' has no entry.",
      "ebp": [
        {"name": "9100 Plan Documents",
         "keywords": ["plan document", "adoption agreement", "amendment",
                      "base plan", "volume submitter", "spd",
                      "summary plan description", "determination letter",
                      "opinion letter", "irs approval", "irs letter",
                      "board resolution", "trust agreement", "trust document"]},
        {"name": "9200 Service Agreements",
         "keywords": ["service agreement", "services agreement", "asa",
                      "recordkeeping agreement", "administrative services",
                      "custody agreement", "custodial agreement",
                      "trustee agreement", "fee schedule", "fee disclosure"]},
        {"name": "9300 SOC 1 Reports",
         "keywords": ["soc 1", "soc1", "soc-1", "soc 2", "soc2",
                      "service auditor", "bridge letter", "gap letter",
                      "service organization"]}
      ]
    }
  },

  "single_audit": {
    "label": "Single Audit tack-on",
    "_comment": "Appends to either client-type index when the engagement is a single audit. Default is one flat 8000 folder; optional_subsections are used only if the user asks for them.",
    "section": ["8000", "Single Audit"],
    "optional_subsections": [
      ["8100", "SEFA"],
      ["8200", "Major Program Compliance"],
      ["8300", "Internal Control over Compliance"]
    ],
